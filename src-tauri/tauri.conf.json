{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "whiplash",
  "version": "0.1.1",
  "identifier": "com.alanr.whiplash",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "whiplash",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**", "http://**", "https://**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzN0QyQ0JEODJEQzE4MEYKUldRUEdOeUN2U3g5ODI5UDhPSXBKT0t6MVBFeVhTWXVpeWR0TFJSTlJVWmdPZjdYeEdRbk92bFYK",
      "endpoints": [
        "https://github.com/alanenggb/whiplash-music-player/releases/latest/download/latest.json"
      ]
    }
  }
}
